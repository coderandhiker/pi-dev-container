{
  "name": "Pi Dev Container",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "mounts": [
    "source=${localWorkspaceFolder}/llm-config,target=/root/.pi/agent,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/workspace,target=/workspace,type=bind,consistency=cached"
  ],
  "remoteUser": "root",
  "postCreateCommand": "validate-tooling",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-dotnettools.csharp",
        "ms-python.python",
        "rust-lang.rust-analyzer",
        "golang.Go",
        "denoland.vscode-deno",
        "oven-sh.bun-vscode"
      ]
    }
  }
}
